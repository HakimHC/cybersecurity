#! /usr/bin/env python3

import argparse
import os
import hashlib
from urllib.parse import urljoin, urlparse
from bs4 import BeautifulSoup
import requests
from dataclasses import dataclass, field
import logging
from pathlib import Path
from requests.exceptions import HTTPError, ConnectionError, Timeout

IMAGE_EXTENSIONS = [".jpg", ".jpeg", ".png", ".gif", ".bmp"]


@dataclass
class Args:
    recursive: bool
    depth: int
    path: str
    url: str

    _MAX_DEPTH: int = field(default=5, init=False, repr=False)

    @staticmethod
    def _validate_url(url: str) -> str:
        parsed = urlparse(url)
        if parsed.scheme not in ("http", "https"):
            raise argparse.ArgumentTypeError("URL must start with http:// or https://")
        if not parsed.netloc:
            raise argparse.ArgumentTypeError("URL must have a valid domain")
        return url

    @staticmethod
    def parse() -> "Args":
        parser = argparse.ArgumentParser(
            description="Web crawler that downloads images"
        )

        _ = parser.add_argument(
            "-r",
            "--recursive",
            action="store_true",
            help="Recursively downloads the images in a URL received as a parameter",
        )

        _ = parser.add_argument(
            "-l",
            "--depth",
            type=int,
            default=None,
            help="Maximum depth level of the recursive download. (Default: 5)",
        )

        _ = parser.add_argument(
            "-p",
            "--path",
            type=str,
            default="./data",
            help='Path where the downloaded files will be saved. (Default: "./data")',
        )

        _ = parser.add_argument(
            "url",
            type=Args._validate_url,
            help="URL to scrape for images.",
        )

        parsed = parser.parse_args()

        if parsed.depth is not None and not parsed.recursive:  # pyright: ignore[reportAny]
            parser.error("--depth required --recursive")

        if parsed.recursive and parsed.depth is None:  # pyright: ignore[reportAny]
            parsed.depth = 5

        if parsed.depth is not None and not (2 <= parsed.depth <= Args._MAX_DEPTH):
            parser.error(f"--depth must be between 2 and {Args._MAX_DEPTH}")

        return Args(
            recursive=parsed.recursive,  # pyright: ignore[reportAny]
            depth=parsed.depth,
            path=parsed.path,  # pyright: ignore[reportAny]
            url=parsed.url,  # pyright: ignore[reportAny]
        )


def list_urls(base_url: str, soup: BeautifulSoup) -> list[str]:
    urls: list[str] = []
    for tag in soup.find_all("a", href=True):
        href = str(tag["href"]).strip()

        if not href or href.startswith(("#", "javascript:", "mailto:", "tel:")):
            continue

        absolute_url = urljoin(base_url, href)

        parsed = urlparse(absolute_url)
        if parsed.scheme not in ("http", "https"):
            continue

        path = parsed.path.lower()
        if any(path.endswith(ext) for ext in IMAGE_EXTENSIONS):
            continue

        clean_url = absolute_url.split("#")[0].rstrip("/")
        urls.append(clean_url)
    return urls


def list_images(base_url: str, soup: BeautifulSoup) -> list[str]:
    urls: list[str] = []

    for tag in soup.find_all("a", href=True):
        href = str(tag["href"]).strip()
        absolute = urljoin(base_url, href)
        if any(absolute.lower().endswith(ext) for ext in IMAGE_EXTENSIONS):
            urls.append(absolute)

    for tag in soup.find_all("img", src=True):
        src = str(tag["src"]).strip()
        absolute = urljoin(base_url, src)
        if any(absolute.lower().endswith(ext) for ext in IMAGE_EXTENSIONS):
            urls.append(absolute)

    return list(dict.fromkeys(urls))  # deduplicate, preserve order


def image_filename(url: str) -> str:
    parsed = urlparse(url)
    basename = os.path.splitext(os.path.basename(parsed.path))
    name, ext = basename
    url_hash = hashlib.sha256(url.encode()).hexdigest()[:8]
    return f"{name}-{url_hash}{ext}"


def download_image(
    url: str, args: Args, out_path: str | Path | None = None
) -> str | Path | None:
    if not out_path:
        img_filename = image_filename(url)
        out_path = os.path.join(args.path, img_filename)

    response = requests.get(url, timeout=10, allow_redirects=True)
    response.raise_for_status()

    if os.path.exists(out_path):
        logging.warning(f"File {out_path} already exists. Overwriting.")
    with open(out_path, "wb") as f:
        _ = f.write(response.content)
    return out_path


visited: set[str] = set()


def crawl(base_url: str, depth: int, args: Args) -> None:
    if depth <= 0 or base_url in visited:
        return

    try:
        response = requests.get(base_url, timeout=10, allow_redirects=True)
    except Exception as e:
        logging.error(f"Unable to visit {base_url} ({e})")
        return

    # if the redirected site is already processed
    if response.url in visited:
        return

    if base_url != response.url:
        base_url = response.url
    visited.add(base_url)

    logging.info(f"Processing {base_url}")
    if "text/html" not in response.headers.get("Content-Type", ""):
        logging.warning(f"URL {base_url} is not HTML. Skipping.")
        return

    soup = BeautifulSoup(response.text, "html.parser")

    images = list_images(base_url, soup)
    for image_url in images:
        out_path = None
        try:
            out_path = download_image(image_url, args)
        except (HTTPError, ConnectionError, Timeout) as e:
            logging.error(f"Unable to download file from {image_url}. ({e})")
        except PermissionError as e:
            logging.error(f"Can't write to {out_path} ({e})")

    urls = list_urls(base_url, soup)
    for url in urls:
        crawl(url, depth - 1, args)


if __name__ == "__main__":
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] %(filename)s:%(lineno)d - %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S",
    )

    args = Args.parse()
    try:
        os.makedirs(args.path, exist_ok=True)
        crawl(args.url, args.depth or 1, args)
        exit(0)
    except RecursionError:
        logging.fatal("fatal: Recursion limit hit.")
    except PermissionError as e:
        logging.fatal(f"Could not create directory: {e}")
    except KeyboardInterrupt:
        logging.info("Keyboard interrupt. Exiting...")
    except Exception as e:
        logging.fatal(f"Unexpected error: {e}")
    exit(1)
